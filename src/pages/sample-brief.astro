---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import Footer from "../components/Footer.astro";
import { COMPANY_NAME, BRIEF_PATH } from "../config";

interface MiniSheet {
  name: string;
  handle: string;
  numLabel: string;
  audience: [string, string];
  overlap: string;
  engagement: string;
  content: string;
  rate: string;
  note: string;
}

type SheetStatus =
  | { kind: "warmed"; label: string }
  | { kind: "confirmed"; label: string }
  | { kind: "awaiting"; label: string };

interface MiniSheetWithStatus extends MiniSheet {
  status: SheetStatus;
}

// 3 of the fictional creators, framed for the Veridian brief.
// Statuses vary deliberately — real pipelines have attrition.
const sheets: MiniSheetWithStatus[] = [
  {
    name: "Maya Linde",
    handle: "@mayalinde · YouTube · Substack",
    numLabel: "01 / 03",
    audience: ["142K subscribers", "71% women, 28–42, US/UK/AU"],
    overlap: "87% with home / slow-living",
    engagement: "8.4% — verified organic",
    content: "Essays · slow living · design",
    rate: "$4.5K – $6.5K · 60–90s integration",
    note: "Briefed Apr 22. Aligned on category fit. Awaiting your go.",
    status: { kind: "warmed", label: "Warmed up — interested" },
  },
  {
    name: "Aisha Adesanya",
    handle: "@aishaadesanya · Podcast · Instagram",
    numLabel: "02 / 03",
    audience: ["88K listeners avg", "Founders, 32–48, US-heavy"],
    overlap: "74% with home (operator-led overlap)",
    engagement: "11.2% — engaged community",
    content: "DTC operators · brand-building · ops",
    rate: "$3.8K – $5K · Mid-roll, 90s",
    note: "Ready. Prefers operator-led narratives. Apr 30 slot.",
    status: { kind: "confirmed", label: "Confirmed for May" },
  },
  {
    name: "Soren Bach",
    handle: "@sorenbach · YouTube · Newsletter",
    numLabel: "03 / 03",
    audience: ["196K subscribers", "58% men, 26–44, EU/US"],
    overlap: "82% with home / industrial design",
    engagement: "9.3% — verified organic",
    content: "Design crit · architecture · industrial",
    rate: "$5K – $7K · 90s integration",
    note: "Selective. Said yes after preview. Ready.",
    status: { kind: "awaiting", label: "Awaiting reply" },
  },
];

const criteria: string[] = [
  "Audience overlap of 70%+ with home / lifestyle category",
  "8K–500K subscribers — engaged-reach, not vanity reach",
  "English-speaking, US / UK / CA / AU primary audience",
  "Has run at least one previous brand integration that landed cleanly",
  "Aesthetic fit: warm, slow, considered — not high-frequency lifestyle vlog",
];
---

<Layout title={`A sample brief — ${COMPANY_NAME}`} path="/sample-brief">
  <SiteNav variant="full" />

  <main
    class="px-6 md:px-10 lg:px-16 pt-32 md:pt-40 pb-24 md:pb-32"
    style="background: var(--color-bg);"
  >
    <article class="max-w-3xl mx-auto">
      <!-- Header -->
      <div
        class="text-xs uppercase tracking-[0.22em]"
        style="color: var(--color-ink-subtle);"
      >
        Sample deliverable · April 2026
      </div>

      <h1
        class="mt-5 font-serif leading-[1.02] tracking-tight"
        style="
          color: var(--color-ink);
          font-size: clamp(2.25rem, 5.5vw, 4.25rem);
        "
      >
        What a CastWorks brief looks like.
      </h1>

      <p
        class="mt-10 md:mt-12 text-lg md:text-xl leading-relaxed"
        style="color: var(--color-ink-muted);"
      >
        Below is a redacted sample of a finished pipeline. We've changed the
        brand and the creator names. The shape of the work is real — each
        entry below represents four to six hours of human work on top of the
        discovery pass.
      </p>

      <!-- "Built for" block -->
      <div
        class="mt-16 md:mt-20 grid grid-cols-1 md:grid-cols-[140px_1fr] gap-4 md:gap-10 py-8 border-t border-b"
        style="border-color: var(--color-rule);"
      >
        <div
          class="text-xs uppercase tracking-[0.22em]"
          style="color: var(--color-ink-subtle);"
        >
          Built for
        </div>
        <div>
          <div
            class="font-serif"
            style="color: var(--color-ink); font-size: clamp(1.375rem, 2.4vw, 1.875rem); line-height: 1.2;"
          >
            Veridian
            <span
              class="ml-2 text-sm font-sans not-italic align-middle"
              style="color: var(--color-ink-subtle);"
            >
              (a fictional brand, redacted from a real engagement)
            </span>
          </div>
          <p
            class="mt-3 text-base md:text-lg leading-relaxed"
            style="color: var(--color-ink-muted);"
          >
            Small home-goods brand. Sub-$30K monthly marketing budget. Looking
            for creators with a slow-living audience that overlaps their
            kitchenware line.
          </p>
        </div>
      </div>

      <!-- Selection criteria -->
      <section class="mt-20 md:mt-24">
        <h2
          class="font-serif tracking-tight"
          style="color: var(--color-ink); font-size: clamp(1.75rem, 3.5vw, 2.5rem); line-height: 1.15;"
        >
          Selection criteria
        </h2>
        <ol
          class="mt-10 space-y-0"
          style="list-style: none;"
        >
          {
            criteria.map((c, i) => (
              <li
                class="grid grid-cols-[40px_1fr] gap-4 py-5 border-t"
                style={`border-color: var(--color-rule); ${i === criteria.length - 1 ? "border-bottom: 1px solid var(--color-rule);" : ""}`}
              >
                <span
                  class="text-xs uppercase tracking-[0.22em] pt-1"
                  style="color: var(--color-ink-subtle);"
                >
                  {String(i + 1).padStart(2, "0")}
                </span>
                <span
                  class="text-base md:text-lg leading-relaxed"
                  style="color: var(--color-ink);"
                >
                  {c}
                </span>
              </li>
            ))
          }
        </ol>
      </section>

      <!-- Pipeline -->
      <section class="mt-20 md:mt-24">
        <h2
          class="font-serif tracking-tight"
          style="color: var(--color-ink); font-size: clamp(1.75rem, 3.5vw, 2.5rem); line-height: 1.15;"
        >
          Pipeline
        </h2>

        <div class="mt-10 space-y-6">
          {
            sheets.map((s) => (
              <article class="mini-tear-sheet">
                <div class="flex justify-between items-baseline">
                  <span
                    class="text-[10px] uppercase tracking-[0.22em]"
                    style="color: var(--color-ink-subtle);"
                  >
                    Tear sheet
                  </span>
                  <span
                    class="text-[10px] uppercase tracking-[0.22em]"
                    style="color: var(--color-ink-subtle);"
                  >
                    {s.numLabel}
                  </span>
                </div>

                <div class="mt-5 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-baseline">
                  <div>
                    <h3
                      class="font-serif leading-tight"
                      style="color: var(--color-ink); font-size: 1.5rem; letter-spacing: -0.01em;"
                    >
                      {s.name}
                    </h3>
                    <p
                      class="mt-1 text-sm"
                      style="color: var(--color-ink-muted);"
                    >
                      {s.handle}
                    </p>
                  </div>
                  <div class="flex items-center gap-2 md:justify-end">
                    {s.status.kind === "awaiting" ? (
                      <>
                        <span
                          class="inline-block w-1.5 h-1.5 rounded-full"
                          style="background: var(--color-ink-subtle);"
                        />
                        <span
                          class="text-[11px] uppercase tracking-[0.2em] font-medium"
                          style="color: var(--color-ink-muted);"
                        >
                          {s.status.label}
                        </span>
                      </>
                    ) : (
                      <>
                        <span
                          class="inline-block w-2 h-2 rounded-full"
                          style="background: var(--color-accent);"
                        />
                        <span
                          class="text-[11px] uppercase tracking-[0.2em] font-medium"
                          style="color: var(--color-accent);"
                        >
                          {s.status.label}
                        </span>
                      </>
                    )}
                  </div>
                </div>

                <hr
                  class="mt-5 border-0"
                  style="height: 1px; background: var(--color-rule);"
                />

                <dl class="mt-5 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4 text-sm">
                  <div class="grid grid-cols-[100px_1fr] gap-3">
                    <dt
                      class="uppercase tracking-[0.18em] text-[10px] pt-[3px]"
                      style="color: var(--color-ink-subtle);"
                    >
                      Audience
                    </dt>
                    <dd style="color: var(--color-ink);">
                      {s.audience[0]}
                      <br />
                      <span style="color: var(--color-ink-muted);">{s.audience[1]}</span>
                    </dd>
                  </div>

                  <div class="grid grid-cols-[100px_1fr] gap-3">
                    <dt
                      class="uppercase tracking-[0.18em] text-[10px] pt-[3px]"
                      style="color: var(--color-ink-subtle);"
                    >
                      Overlap
                    </dt>
                    <dd style="color: var(--color-ink);">{s.overlap}</dd>
                  </div>

                  <div class="grid grid-cols-[100px_1fr] gap-3">
                    <dt
                      class="uppercase tracking-[0.18em] text-[10px] pt-[3px]"
                      style="color: var(--color-ink-subtle);"
                    >
                      Engagement
                    </dt>
                    <dd style="color: var(--color-ink);">{s.engagement}</dd>
                  </div>

                  <div class="grid grid-cols-[100px_1fr] gap-3">
                    <dt
                      class="uppercase tracking-[0.18em] text-[10px] pt-[3px]"
                      style="color: var(--color-ink-subtle);"
                    >
                      Content
                    </dt>
                    <dd style="color: var(--color-ink);">{s.content}</dd>
                  </div>

                  <div class="grid grid-cols-[100px_1fr] gap-3 md:col-span-2">
                    <dt
                      class="uppercase tracking-[0.18em] text-[10px] pt-[3px]"
                      style="color: var(--color-ink-subtle);"
                    >
                      Rate
                    </dt>
                    <dd style="color: var(--color-ink);">{s.rate}</dd>
                  </div>
                </dl>

                <p
                  class="mt-5 text-sm font-serif italic leading-snug"
                  style="color: var(--color-ink-muted);"
                >
                  &ldquo;{s.note}&rdquo;
                </p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- Sign-off -->
      <div class="mt-20 md:mt-24">
        <p class="mt-12 md:mt-14 text-base md:text-lg" style="color: var(--color-ink-muted);">
          Want one of these built for your brand?
          <a
            href={BRIEF_PATH}
            class="ml-1"
            style="color: var(--color-accent); text-decoration: underline; text-underline-offset: 4px; text-decoration-thickness: 1px;"
          >
            Submit a brief &rarr;
          </a>
        </p>
        <p
          class="mt-10 text-xs italic"
          style="color: var(--color-ink-subtle); font-family: var(--font-serif);"
        >
          — Sample, April 2026
        </p>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .mini-tear-sheet {
    background: var(--color-bg-card);
    border: 1px solid var(--color-rule);
    border-radius: 2px;
    padding: 1.75rem 1.75rem 1.5rem;
    box-shadow: 0 1px 8px -4px rgba(20, 20, 20, 0.1);
  }
</style>
