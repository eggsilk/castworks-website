---
// Hidden source page for the og-image.png Open Graph card.
// Renders a 1200x630 design that we screenshot to public/og-image.png.
// Not linked from the site. Kept in repo so re-exports are easy when
// hero copy or brand colors shift.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>OG image source</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { background: #2a2a2a; }
      body {
        font-family: "Inter", system-ui, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
      }
      .card {
        width: 1200px;
        height: 630px;
        background: #1F3A34;
        color: #FAF8F3;
        padding: 80px 96px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        position: relative;
      }
      .wordmark {
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 18px;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: #FAF8F3;
      }
      .headline {
        font-family: "Instrument Serif", Georgia, serif;
        font-style: italic;
        font-weight: 400;
        font-size: 96px;
        line-height: 1.04;
        letter-spacing: -0.015em;
        color: #FAF8F3;
        max-width: 920px;
      }
      .footer {
        display: flex;
        align-items: center;
        gap: 24px;
      }
      .rule {
        width: 56px;
        height: 1px;
        background: #FAF8F3;
        opacity: 0.55;
      }
      .url {
        font-family: "Inter", sans-serif;
        font-weight: 400;
        font-size: 18px;
        letter-spacing: 0.04em;
        color: #FAF8F3;
        opacity: 0.85;
      }
    </style>
  </head>
  <body>
    <div class="card" id="og-card">
      <div class="wordmark">CASTWORKS</div>
      <div class="headline">
        The risk-free<br />infrastructure<br />for creator marketing.
      </div>
      <div class="footer">
        <div class="rule"></div>
        <div class="url">castworks.co</div>
      </div>
    </div>
  </body>
</html>
