---
import Layout from "../layouts/Layout.astro";
import SiteNav from "../components/SiteNav.astro";
import TerminalCTA from "../components/TerminalCTA.astro";
import Footer from "../components/Footer.astro";
import { COMPANY_NAME, HOME_PATH } from "../config";
---

<Layout title={`Submit a brief — ${COMPANY_NAME}`} path="/brief">
  <SiteNav variant="full" />

  <main style="background: var(--color-bg);">
    <h1 class="sr-only">Submit a brief — CastWorks</h1>

    <!-- Breadcrumb / back link -->
    <div
      class="px-6 md:px-10 lg:px-16 pt-32 md:pt-40 pb-0"
    >
      <div class="max-w-2xl mx-auto">
        <a
          href={HOME_PATH}
          class="inline-flex items-center gap-2 text-sm transition-colors duration-200"
          style="color: var(--color-ink-muted);"
          onmouseover="this.style.color='var(--color-ink)'"
          onmouseout="this.style.color='var(--color-ink-muted)'"
        >
          <span aria-hidden="true">&larr;</span>
          Back to how we work
        </a>
      </div>
    </div>

    <TerminalCTA />
  </main>

  <Footer />
</Layout>
