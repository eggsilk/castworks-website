---
// Sign-off CTA on /home — replaces the inline TerminalCTA on the methodology page.
// Editorial pull-quote-style heading + single button to /brief.
import { BRIEF_PATH } from "../config";
---

<section
  class="py-32 md:py-44 px-6 md:px-10 lg:px-16"
  style="background: var(--color-bg); border-top: 1px solid var(--color-rule);"
>
  <div class="max-w-3xl mx-auto">
    <h2
      data-reveal
      class="font-serif leading-[1.02] tracking-tight"
      style="
        color: var(--color-ink);
        font-size: clamp(2.25rem, 5.5vw, 4.5rem);
      "
    >
      Ready when you are.
    </h2>

    <div
      data-reveal
      data-reveal-delay="1"
      class="mt-10 md:mt-12"
    >
      <a
        href={BRIEF_PATH}
        class="inline-flex items-center gap-2 text-base md:text-lg"
        style="color: var(--color-accent); text-decoration: underline; text-underline-offset: 6px; text-decoration-thickness: 1px;"
      >
        Submit a brief
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>

    <p
      data-reveal
      data-reveal-delay="2"
      class="mt-8 md:mt-10 max-w-xl text-base md:text-lg leading-relaxed"
      style="color: var(--color-ink-muted);"
    >
      Two business days to a response. Hand-written, not templated.
    </p>
  </div>
</section>
