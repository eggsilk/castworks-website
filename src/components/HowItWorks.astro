---
const steps = [
  {
    number: "01",
    title: "Discovery call",
    body: "You describe your target audience — demographics, geography, niche, tone. We scope the search and confirm fit.",
  },
  {
    number: "02",
    title: "Automated matching",
    body: "Our engine scores creators against your brief: engagement quality, audience location, commercial history, and content fit — all scored programmatically.",
  },
  {
    number: "03",
    title: "Package review",
    body: "We present a ranked shortlist with per-creator rationale. You select the bundle before anything goes to creators.",
  },
  {
    number: "04",
    title: "We handle the rest",
    body: "Outreach, negotiation, contracts, placement tracking. You approve the package; we close it.",
  },
];
---

<section id="how-it-works" class="py-28 px-6" style="background-color: #ffffff;">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-2xl mb-16" data-reveal>
      <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: #335CFF;">
        How it works
      </p>
      <h2 class="text-slate-900 text-4xl sm:text-5xl font-bold tracking-tight leading-tight">
        Brief to bundle in days, not weeks
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      {
        steps.map((step, i) => (
          <div
            class="rounded-2xl p-8 transition-all duration-300 hover:-translate-y-0.5"
            data-reveal
            data-reveal-delay={String(i + 1)}
            style="background: #F8F7F4; border: 1px solid rgba(51,92,255,0.08);"
          >
            <div class="flex items-start gap-5">
              <div
                class="shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-mono text-xs font-bold"
                style="background: rgba(51,92,255,0.08); color: #335CFF;"
              >
                {step.number}
              </div>
              <div>
                <h3 class="text-slate-900 text-lg font-bold mb-2">{step.title}</h3>
                <p class="text-slate-500 text-sm leading-relaxed">{step.body}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
