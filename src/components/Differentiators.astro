---
import { COMPANY_NAME } from "../config";

const points = [
  {
    title: "The tier nobody else serves",
    body: "Every agency sets a floor. Ours is lower — by design. The 1K–20K range is where niche precision lives, and where we've built the infrastructure to operate at scale.",
  },
  {
    title: "Automated, not a headcount problem",
    body: "Discovery runs programmatically. That's why we can offer packages at budgets and turnaround speeds a traditional agency can't match without growing their team.",
  },
  {
    title: "Commission-based, fully aligned",
    body: "We get paid when deals close. No retainer, no platform fee, no minimum spend. Our incentive is your outcome — the model is designed that way.",
  },
];
---

<section id="why-castworks" class="py-28 px-6" style="background-color: #F8F7F4;">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-2xl mb-16" data-reveal>
      <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: #335CFF;">
        Why {COMPANY_NAME}
      </p>
      <h2 class="text-slate-900 text-4xl sm:text-5xl font-bold tracking-tight leading-tight">
        Built for a market gap, not a market that already exists
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {
        points.map((p, i) => (
          <div data-reveal data-reveal-delay={String(i + 1)}>
            <div class="mb-6">
              <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="36" height="36" rx="10" fill="rgba(51,92,255,0.08)"/>
                <rect x="11" y="17.25" width="14" height="1.5" rx="0.75" fill="#335CFF"/>
                <rect x="17.25" y="11" width="1.5" height="14" rx="0.75" fill="#335CFF" opacity="0.45"/>
              </svg>
            </div>
            <h3 class="text-slate-900 text-xl font-bold mb-3">{p.title}</h3>
            <p class="text-slate-500 leading-relaxed">{p.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
