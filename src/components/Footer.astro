---
import { COMPANY_NAME, CONTACT_EMAIL } from "../config";
---

<footer
  class="border-t border-slate-800 py-10 px-6"
  style="background-color: #0b0d11;"
>
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <span class="text-slate-500 text-sm font-medium">{COMPANY_NAME}</span>
    <a
      href={`mailto:${CONTACT_EMAIL}`}
      class="text-slate-500 hover:text-white text-sm transition-colors"
    >
      {CONTACT_EMAIL}
    </a>
    <span class="text-slate-700 text-sm">
      &copy; {new Date().getFullYear()}
    </span>
  </div>
</footer>
