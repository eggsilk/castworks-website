---
import { COMPANY_NAME, APPLY_ANCHOR, HOW_IT_WORKS_ANCHOR } from "../config";
---

<nav
  data-nav
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-10 lg:px-16 py-5 md:py-6"
>
  <a
    href="/"
    class="font-serif tracking-tight text-3xl md:text-5xl leading-none"
    style="color: var(--color-ink);"
  >
    {COMPANY_NAME}
  </a>

  <div class="flex items-center gap-6 md:gap-8">
    <a
      href={HOW_IT_WORKS_ANCHOR}
      class="hidden sm:inline text-sm transition-colors duration-200"
      style="color: var(--color-ink-muted);"
      onmouseover="this.style.color='var(--color-ink)'"
      onmouseout="this.style.color='var(--color-ink-muted)'"
    >
      How it works
    </a>

    <a
      href={APPLY_ANCHOR}
      class="text-sm font-medium px-4 py-2 rounded-md transition-all duration-200 hover:opacity-90"
      style="background: var(--color-accent); color: var(--color-dark-text);"
    >
      See if you qualify
    </a>
  </div>
</nav>

<script>
  const nav = document.querySelector<HTMLElement>("nav[data-nav]");
  if (nav) {
    nav.style.transition =
      "background-color 0.25s ease, border-color 0.25s ease, backdrop-filter 0.25s ease, -webkit-backdrop-filter 0.25s ease";
    nav.style.borderBottom = "1px solid transparent";

    const update = () => {
      const scrolled = window.scrollY > 24;
      nav.dataset.scrolled = scrolled ? "true" : "false";
      if (scrolled) {
        nav.style.backgroundColor = "rgba(250, 248, 243, 0.85)";
        (nav.style as any).backdropFilter = "saturate(140%) blur(10px)";
        (nav.style as any).webkitBackdropFilter = "saturate(140%) blur(10px)";
        nav.style.borderBottomColor = "var(--color-rule)";
      } else {
        nav.style.backgroundColor = "transparent";
        (nav.style as any).backdropFilter = "none";
        (nav.style as any).webkitBackdropFilter = "none";
        nav.style.borderBottomColor = "transparent";
      }
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
  }
</script>
