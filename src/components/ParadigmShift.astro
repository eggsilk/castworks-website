---
// Section 3 — Paradigm Shift
// "The third option." — resolves the tension from Section 2 (databases + agencies both broken).
// Paired on the right with a "creator universe → shortlist" constellation visual.
// (The four-step pipeline flow lives in Section 4 / Methodology — this section stays
// at the "what we are" level, not the operational "how it runs" level.)
---

<section
  id="approach"
  class="py-20 md:py-28 px-6 md:px-10 lg:px-16"
  style="background: var(--color-bg);"
>
  <div class="max-w-6xl mx-auto">
    <!-- Top block: two-column on desktop — text left, visual right -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 lg:gap-24 items-start">
      <!-- Left column: heading + body -->
      <div>
        <h2
          data-reveal
          class="font-serif leading-[1.02] tracking-tight"
          style="
            color: var(--color-ink);
            font-size: clamp(1.75rem, 4vw, 3rem);
          "
        >
          Engineered for you.
        </h2>

        <div
          data-reveal
          data-reveal-delay="1"
          class="mt-10 md:mt-14 space-y-6 text-lg md:text-xl leading-relaxed"
          style="color: var(--color-ink-muted);"
        >
          <p>
            We built our own tooling for the work a sourcing analyst does.
            Audience overlap. Content fit. Engagement quality. Commercial
            signal. The parts that don't scale, we still do by hand.
          </p>
        </div>
      </div>

      <!-- Right column: "creator universe to shortlist" composition -->
      <div
        data-reveal
        data-reveal-delay="2"
        class="md:pt-6 lg:pt-10 flex flex-col items-start"
      >
        <svg
          viewBox="0 0 500 500"
          class="w-full max-w-[460px] h-auto"
          role="img"
          aria-label="Creator universe visualization: many creators narrowed to a shortlist."
        >
          <!-- Background: creator universe (muted dots) -->
          <g style="fill: var(--color-ink-subtle); opacity: 0.42;">
            <circle cx="40" cy="60" r="2" />
            <circle cx="75" cy="130" r="1.8" />
            <circle cx="30" cy="200" r="2" />
            <circle cx="100" cy="70" r="1.6" />
            <circle cx="140" cy="40" r="2" />
            <circle cx="180" cy="110" r="1.8" />
            <circle cx="220" cy="60" r="2" />
            <circle cx="270" cy="40" r="1.6" />
            <circle cx="340" cy="70" r="2" />
            <circle cx="400" cy="50" r="1.8" />
            <circle cx="460" cy="100" r="2" />
            <circle cx="440" cy="40" r="1.6" />
            <circle cx="70" cy="260" r="1.8" />
            <circle cx="35" cy="330" r="2" />
            <circle cx="60" cy="400" r="1.8" />
            <circle cx="100" cy="360" r="2" />
            <circle cx="150" cy="440" r="1.6" />
            <circle cx="40" cy="470" r="2" />
            <circle cx="180" cy="390" r="1.8" />
            <circle cx="230" cy="420" r="2" />
            <circle cx="200" cy="475" r="1.6" />
            <circle cx="100" cy="465" r="1.8" />
            <circle cx="395" cy="430" r="2" />
            <circle cx="445" cy="380" r="1.8" />
            <circle cx="472" cy="430" r="1.6" />
            <circle cx="450" cy="290" r="2" />
            <circle cx="470" cy="210" r="1.8" />
            <circle cx="350" cy="50" r="1.6" />
            <circle cx="460" cy="160" r="2" />
            <circle cx="380" cy="190" r="1.8" />
            <circle cx="418" cy="250" r="1.6" />
            <circle cx="430" cy="340" r="2" />
            <circle cx="350" cy="400" r="1.8" />
            <circle cx="90" cy="210" r="1.6" />
            <circle cx="30" cy="140" r="2" />
            <circle cx="160" cy="200" r="1.8" />
            <circle cx="250" cy="470" r="1.6" />
            <circle cx="60" cy="280" r="1.8" />
            <circle cx="190" cy="250" r="2" />
            <circle cx="145" cy="290" r="1.6" />
            <circle cx="125" cy="165" r="1.8" />
            <circle cx="215" cy="155" r="1.6" />
            <circle cx="255" cy="120" r="1.8" />
          </g>

          <!-- Dashed selection boundary -->
          <circle
            cx="315"
            cy="265"
            r="78"
            fill="none"
            style="stroke: var(--color-ink-subtle); stroke-width: 0.8; stroke-dasharray: 3 4; opacity: 0.55;"
          />

          <!-- Constellation lines connecting shortlist -->
          <g style="stroke: var(--color-ink); stroke-width: 0.8; fill: none; opacity: 0.45;">
            <line x1="270" y1="228" x2="308" y2="220" />
            <line x1="308" y1="220" x2="350" y2="240" />
            <line x1="308" y1="220" x2="295" y2="265" />
            <line x1="295" y1="265" x2="335" y2="275" />
            <line x1="335" y1="275" x2="365" y2="248" />
            <line x1="295" y1="265" x2="315" y2="310" />
            <line x1="315" y1="310" x2="355" y2="300" />
            <line x1="270" y1="228" x2="295" y2="265" />
          </g>

          <!-- Foreground: shortlist (ink dots) -->
          <g style="fill: var(--color-ink);">
            <circle cx="270" cy="228" r="3.2" />
            <circle cx="308" cy="220" r="3.4" />
            <circle cx="350" cy="240" r="3.2" />
            <circle cx="365" cy="248" r="2.8" />
            <circle cx="295" cy="265" r="3.6" />
            <circle cx="335" cy="275" r="3.2" />
            <circle cx="315" cy="310" r="3" />
            <circle cx="355" cy="300" r="2.8" />
          </g>
        </svg>

        <!-- Caption -->
        <div
          class="mt-6 text-xs uppercase tracking-[0.22em] flex items-center gap-3"
          style="color: var(--color-ink-subtle);"
        >
          <span>Creator universe</span>
          <svg viewBox="0 0 24 8" width="24" height="8" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="0" y1="4" x2="20" y2="4" />
            <polyline points="16 1 20 4 16 7" />
          </svg>
          <span>Your shortlist</span>
        </div>
      </div>
    </div>
  </div>
</section>
