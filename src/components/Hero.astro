---
// Softened hero used on /home — methodology page.
// CTAs intentionally removed (this page is the methodology, not the entry).
// Headline + sub only.
---

<section
  class="relative min-h-screen flex flex-col"
  style="background: var(--color-bg);"
>
  <div
    class="flex-1 flex items-center px-6 md:px-10 lg:px-16 pt-32 md:pt-36 pb-16"
  >
    <div class="w-full max-w-6xl mx-auto">
      <!-- Headline -->
      <h1
        class="hero-animate font-serif leading-[0.96] tracking-tight"
        style="
          color: var(--color-ink);
          font-size: clamp(2.5rem, 6vw, 5.5rem);
        "
      >
        The work between a database and a campaign.
      </h1>

      <!-- Sub-line -->
      <div
        class="hero-animate hero-delay-1 mt-10 md:mt-12 max-w-2xl"
        style="color: var(--color-ink-muted);"
      >
        <p class="text-lg md:text-xl leading-relaxed">
          Strategy, sourcing, outreach, hand-off — handled in-house, per brief.
        </p>
      </div>
    </div>
  </div>
</section>
