---
// Editorial splash hero — single screen.
// Left half: wordmark space (taken by SiteNav), headline, sub, single CTA.
// Right half (desktop) / below (mobile): atmospheric tear-sheet fragment —
// minimal, document-feeling. Communicates "we make these documents" without
// claiming we've shipped them with named brands.
import { HOME_PATH } from "../config";
---

<section
  class="relative min-h-screen flex flex-col"
  style="background: var(--color-bg);"
>
  <div
    class="flex-1 flex items-center px-6 md:px-10 lg:px-16 pt-32 md:pt-36 pb-16"
  >
    <div class="w-full max-w-6xl mx-auto">
      <!-- Two-column on desktop, stacked on mobile (headline first) -->
      <div
        class="grid grid-cols-1 md:grid-cols-[1.15fr_1fr] gap-12 md:gap-16 lg:gap-24 items-center"
      >
        <!-- Left: copy -->
        <div>
          <h1
            class="hero-animate font-serif leading-[0.96] tracking-tight"
            style="
              color: var(--color-ink);
              font-size: clamp(2.5rem, 6vw, 5.5rem);
            "
          >
            Creator marketing, <em class="italic">hand-built</em>.
          </h1>

          <div
            class="hero-animate hero-delay-1 mt-8 md:mt-10 max-w-xl"
            style="color: var(--color-ink-muted);"
          >
            <p class="text-lg md:text-xl leading-relaxed">
              We build a creator pipeline by hand. One brief at a time.
            </p>
          </div>

          <div
            class="hero-animate hero-delay-2 mt-10 md:mt-14 flex flex-col sm:flex-row items-start sm:items-center gap-5 sm:gap-8"
          >
            <a
              href={HOME_PATH}
              class="inline-flex items-center gap-2 text-base"
              style="color: var(--color-accent); text-decoration: underline; text-underline-offset: 6px; text-decoration-thickness: 1px;"
            >
              How we work
              <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </div>

        <!-- Right: atmospheric tear-sheet fragment. Mobile: appears below copy. -->
        <div
          class="hero-animate hero-delay-3 flex justify-center md:justify-end"
        >
          <article
            class="splash-tear-sheet"
            aria-label="Sample tear sheet fragment: Maya Linde"
          >
            <div class="flex justify-between items-baseline">
              <span
                class="text-[10px] uppercase tracking-[0.22em]"
                style="color: var(--color-ink-subtle);"
              >
                Dossier &middot; 03 / 09
              </span>
              <span
                class="text-[10px] uppercase tracking-[0.22em]"
                style="color: var(--color-ink-subtle);"
              >
                Apr 2026
              </span>
            </div>

            <div class="mt-6">
              <h3
                class="font-serif leading-tight"
                style="
                  color: var(--color-ink);
                  font-size: 1.875rem;
                  letter-spacing: -0.01em;
                "
              >
                Maya Linde
              </h3>
              <p
                class="mt-1 text-sm"
                style="color: var(--color-ink-muted);"
              >
                @mayalinde &middot; Essays &middot; slow living
              </p>
            </div>

            <hr
              class="mt-6 border-0"
              style="height: 1px; background: var(--color-rule);"
            />

            <p
              class="mt-5 text-sm font-serif italic leading-snug"
              style="color: var(--color-ink-muted);"
            >
              &ldquo;Briefed Apr 22. Aligned on category fit. Awaiting your
              go.&rdquo;
            </p>

            <div class="mt-5 flex items-center gap-2">
              <span
                class="inline-block w-2 h-2 rounded-full"
                style="background: var(--color-accent);"
              />
              <span
                class="text-[11px] uppercase tracking-[0.2em] font-medium"
                style="color: var(--color-accent);"
              >
                Warmed up — interested
              </span>
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .splash-tear-sheet {
    width: 100%;
    max-width: 360px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-rule);
    border-radius: 2px;
    box-shadow: 0 2px 16px -8px rgba(20, 20, 20, 0.14);
    padding: 2rem 2rem 1.75rem;
    /* Slight perspective lift, like an editorial book cover. */
    transform: rotate(-0.4deg);
    transition: transform 400ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .splash-tear-sheet:hover {
    transform: rotate(0deg) translateY(-2px);
  }
</style>
